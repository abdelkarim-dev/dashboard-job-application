{
  "manifest_version": 3,
  "name": "Claire — Job Hunt Copilot",
  "description": "Capture job posts into Claire, your local job-hunt copilot.",
  "version": "1.6.0",
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Toggle Claire toolbar"
  },
  "permissions": [
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "lib/extract.js",
        "content.js"
      ],
      "run_at": "document_idle",
      "all_frames": true
    }
  ]
}
