{
  "name": "job-hunt-cockpit",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "tsx back/server.mjs",
    "test": "node --import tsx --test back/test/*.test.mjs front/test/*.test.mjs extension/test/*.test.mjs",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "tsx watch back/server.mjs",
    "dev:client": "vite",
    "build": "vite build",
    "check": "node --check back/server.mjs && node --check back/database.mjs && find back/lib -name '*.mjs' -print0 | xargs -0 -n1 node --check && node --check extension/lib/extract.js && node --check extension/content.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "ace-builds": "^1.44.0",
    "express": "^5.2.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^10.0.3",
    "tsx": "^4.22.4",
    "typescript": "^5.0.0",
    "vite": "^8.0.14"
  }
}
