{
  "name": "job-hunt-cockpit",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "node server.mjs",
    "test": "node --test",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "node server.mjs",
    "dev:client": "vite",
    "build": "vite build",
    "check": "node --check server.mjs && node --check database.mjs && find lib -name '*.mjs' -print0 | xargs -0 -n1 node --check && node --check extension/content.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "ace-builds": "^1.44.0",
    "express": "^5.2.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^10.0.3",
    "typescript": "^5.0.0",
    "vite": "^8.0.14"
  }
}
