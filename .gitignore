# Dependencies and generated files
node_modules/
coverage/
.DS_Store

# Local environment / secrets (loaded by server.mjs via process.loadEnvFile)
.env
.env.local

# Local logs
*.log
server.log

# Private job hunt data
data/*.json
data/*.bak
data/*.csv
data/*.db
data/*.db-journal
data/*.db-wal
# Stray/local SQLite files (real DB lives in data/)
cockpit.db
*.db-journal
*.db-wal

# Claude Code: ignore personal/local/session state, but track shared project
# config (agents, workflows, commands, skills, settings.json) so the repo keeps it.
.claude/settings.local.json
.claude/*.local.json
.claude/*.lock
.claude/worktrees/

# Build output (generated by `npm run build`)
dist/

# Editor metadata
.idea/
.vscode/
